# ─────────────────────────────────────────────────────────────────────────────
# Treasure of the Hills — environment variables
# Copy this file to `.env.local` and fill in the values. None are required for
# the site to run; without them, form submissions are logged on the server and
# still show a success message (handy for previews). Add them to turn on real
# email delivery.
# ─────────────────────────────────────────────────────────────────────────────

# Resend API key — enables real email delivery for the contact/membership/
# rental/newsletter forms. Create one (free tier available) at:
#   https://resend.com/api-keys
RESEND_API_KEY=

# Where inquiry emails are sent (the center's inbox).
# If omitted, falls back to the address in src/lib/site-config.ts.
CONTACT_TO_EMAIL=info@toth-seniors.com

# The "from" address shown on inquiry emails. Must be on a domain you've
# verified in Resend (https://resend.com/domains). For quick testing you can
# use Resend's shared sender: "TOTH Website <onboarding@resend.dev>".
CONTACT_FROM_EMAIL="Treasure of the Hills <onboarding@resend.dev>"

# Public site URL — used for SEO canonical tags, Open Graph, and the sitemap.
# Set this to the production domain at deploy time.
NEXT_PUBLIC_SITE_URL=https://www.toth-seniors.com
